TYRS_HAND_ENV=development
# 生产环境必须改为完整的 image@sha256:... 引用。
TYRS_HAND_CONTROL_IMAGE=ghcr.io/slovx2/tyrs-hand-control:0.1.0
TYRS_HAND_WORKER_IMAGE=ghcr.io/slovx2/tyrs-hand-worker:0.1.0
# 生产环境必须配置完整的 image@sha256:... 引用；新环境和显式 Rebase 才会采用新值。
TYRS_HAND_DEVELOPMENT_IMAGE=
TYRS_HAND_HOST_PORT=8080
TYRS_HAND_HTTP_ADDR=:8080
TYRS_HAND_SEPARATE_WEBHOOK=false
TYRS_HAND_WEBHOOK_HTTP_ADDR=:8081
TYRS_HAND_PUBLIC_URL=http://localhost:8080
TYRS_HAND_GITHUB_APP_NAME=TyrsHand
TYRS_HAND_GITHUB_API_URL=https://api.github.com
TYRS_HAND_INTERNAL_SERVER_URL=http://localhost:8080
POSTGRES_PASSWORD=tyrs_hand
TYRS_HAND_DATABASE_URL=postgres://tyrs_hand:tyrs_hand@localhost:5432/tyrs_hand?sslmode=disable
TYRS_HAND_REDIS_URL=redis://localhost:6379/0
TYRS_HAND_SETUP_TOKEN=replace-with-a-long-random-value
# 32 字节随机值的 base64 编码
TYRS_HAND_MASTER_KEY=
TYRS_HAND_COOKIE_SECURE=false
TYRS_HAND_WORKER_DATA_ROOT=.local/worker
TYRS_HAND_REPO_CACHE_ROOT=.local/worker/repo-cache
TYRS_HAND_WORKTREE_ROOT=.local/worker/workspaces/github
TYRS_HAND_CODEX_HOME_ROOT=.local/worker/codex-homes
TYRS_HAND_ATTACHMENT_ROOT=.local/control/attachments
TYRS_HAND_CODEX_BIN=codex
TYRS_HAND_REPO_CACHE_MAX_BYTES=21474836480
TYRS_HAND_WORKER_ID=
TYRS_HAND_WORKER_MAX_CONCURRENT_JOBS=6
TYRS_HAND_WORKER_CONTROL_URL=
TYRS_HAND_WORKER_CREDENTIAL_FILE=.local/worker/control-state/node-credential
TYRS_HAND_WORKER_ENROLLMENT_TOKEN=
TYRS_HAND_WORKER_PROTOCOL_VERSION=9
# 逗号分隔，支持单个 IPv4/IPv6 或 CIDR；留空表示不限制。
TYRS_HAND_WORKER_API_IP_ALLOWLIST=
# 只有来自这些代理网段时才信任 X-Forwarded-For。
TYRS_HAND_WORKER_API_TRUSTED_PROXIES=127.0.0.1/32,::1/128
TYRS_HAND_CODEX_STATUS_POLL_INTERVAL=30s
TYRS_HAND_CODEX_RECONCILE_MAX_ATTEMPTS=3
TYRS_HAND_CODEX_RESULT_DELIVERY_MAX_ATTEMPTS=5
TYRS_HAND_CODEX_MAX_STEERS_PER_TURN=5
TYRS_HAND_GITHUB_REPLY_GATE_MAX_BLOCKS=3
# 只有 Discord Dev Worker 启用并挂载 Docker Socket。
TYRS_HAND_ENABLE_DEVELOPMENT_CONTAINERS=false
TYRS_HAND_DEVELOPMENT_RUNTIME_DIR=.local/worker/development-runtime
TYRS_HAND_DEVELOPMENT_RUNTIME_HOST_DIR=.local/worker/development-runtime
TYRS_HAND_DOCKER_GID=
TYRS_HAND_ENABLE_SSH=false
TYRS_HAND_SSH_AGENT_DIR=/run/tyrs-hand-ssh-agent
TYRS_HAND_SSH_AGENT_HOST_DIR=/opt/tyrs-hand/ssh-agent
TYRS_HAND_BROWSER_MCP_URL=
TYRS_HAND_BROWSER_MCP_TOKEN_FILE=/run/tyrs-hand-browser/browser_mcp_token
TYRS_HAND_BROWSER_FILES_ROOT=/run/tyrs-hand-browser-files
TYRS_HAND_BROWSER_FILES_HOST_ROOT=/opt/tyrs-hand/browser-files
