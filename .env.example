TYRS_HAND_ENV=development
TYRS_HAND_HTTP_ADDR=:8080
TYRS_HAND_PUBLIC_URL=http://localhost:8080
TYRS_HAND_GITHUB_API_URL=https://api.github.com
TYRS_HAND_INTERNAL_SERVER_URL=http://localhost:8080
TYRS_HAND_DATABASE_URL=postgres://tyrs_hand:tyrs_hand@localhost:5432/tyrs_hand?sslmode=disable
TYRS_HAND_REDIS_URL=redis://localhost:6379/0
TYRS_HAND_SETUP_TOKEN=replace-with-a-long-random-value
# 32 字节随机值的 base64 编码
TYRS_HAND_MASTER_KEY=
TYRS_HAND_COOKIE_SECURE=false
TYRS_HAND_REPO_CACHE_ROOT=.local/repo-cache
TYRS_HAND_WORKTREE_ROOT=.local/worktrees
TYRS_HAND_CODEX_HOME_ROOT=.local/codex-homes
TYRS_HAND_CODEX_BIN=codex
TYRS_HAND_REPO_CACHE_MAX_BYTES=21474836480
TYRS_HAND_WORKER_ID=worker-local
