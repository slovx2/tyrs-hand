{
  "name": "tyrs-hand-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.14.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --pretty false",
    "lint": "tools/lint/node_modules/.bin/eslint --config eslint.config.js src vite.config.ts playwright.config.ts --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:run": "vitest run --coverage",
    "e2e": "playwright test",
    "generate:api": "pnpm --dir tools/openapi-ts exec openapi-typescript ../../../api/openapi.yaml -o ../../src/api/schema.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "5.2.2",
    "@tanstack/react-query": "5.101.2",
    "@tailwindcss/vite": "4.3.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.82.0",
    "react-router": "7.18.1",
    "tailwindcss": "4.3.3",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.10.13",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.0",
    "jsdom": "29.1.1",
    "msw": "2.15.0",
    "prettier": "3.9.0",
    "typescript": "7.0.2",
    "vite": "8.1.5",
    "vitest": "4.1.0"
  }
}
